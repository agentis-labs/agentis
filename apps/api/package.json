{
  "name": "@agentis/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./bootstrap": "./src/bootstrap.ts",
    "./backup": "./src/services/backup.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:once": "tsx src/index.ts",
    "start": "node --experimental-strip-types src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'ok'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agentis/core": "workspace:*",
    "@agentis/db": "workspace:*",
    "@agentis/integrations": "workspace:*",
    "@hono/node-server": "^1.13.1",
    "@hono/zod-openapi": "^0.16.0",
    "@scalar/hono-api-reference": "^0.5.150",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.34.0",
    "hono": "^4.6.3",
    "jose": "^5.9.3",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "socket.io": "^4.8.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
}
