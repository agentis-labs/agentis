# ── Agentis configuration (copy to .env; never commit .env) ───────────────────
# All values are optional; sane defaults are used when unset.

# ── Storage ───────────────────────────────────────────────────────────────────
# Data root: SQLite DB, secrets, per-agent homes, backups. Git-ignored.
# AGENTIS_DATA_DIR=./.agentis

# Content-addressed asset store (generated media/blobs). Defaults to
# {AGENTIS_DATA_DIR}/assets. Point it anywhere OUTSIDE the repo — an external
# drive, OneDrive, a NAS — so large media never bloats the source tree or the
# system disk. Deduped by content hash.
# AGENTIS_ASSETS_DIR=D:/agentis-assets

# Working root for the (optional) store-factory demo pipeline. Must be the
# project that holds the store-demo scripts. No default — set it to use that
# feature; otherwise store_factory_* extensions error clearly.
# AGENTIS_STORES_DIR=

# ── Server ────────────────────────────────────────────────────────────────────
# AGENTIS_HTTP_PORT=3737
# AGENTIS_HTTP_HOST=127.0.0.1

# ── Auth seed (first boot only) ───────────────────────────────────────────────
# AGENTIS_SEED_USERNAME=operator
# AGENTIS_SEED_PASSWORD=

# ── Deploy credentials (operator-provided; NEVER commit real values) ──────────
# Used only by the optional store-factory deploy step.
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=

# ── Security hardening (see SECURITY.md) ──────────────────────────────────────
# Extension sandbox. Registry/agent-authored extensions default to the built-in
# `node:vm` fallback, which is NOT a security boundary. For untrusted code,
# install a real isolate (`pnpm add -w isolated-vm`) or enable Docker, and turn
# on require-isolate to fail closed instead of silently using the weak fallback.
# AGENTIS_EXTENSION_DOCKER=true
# AGENTIS_EXTENSION_REQUIRE_ISOLATE=true
#
# Outbound HTTP from extensions/agents is SSRF-guarded and IP-pinned by default.
# Only set this if a workflow legitimately must reach private/loopback services;
# it disables the private-address block and is logged on use.
# AGENTIS_EXTENSION_HTTP_ALLOW_PRIVATE=true
#
# Max concurrent SANDBOX extension executions (node_worker/docker). Bounds a
# runaway/prompt-injected extension loop from exhausting host resources. Default 8.
# AGENTIS_EXTENSION_MAX_CONCURRENT=8

# ── Model runtimes (opt-in) ───────────────────────────────────────────────────
# AGENTIS_ORCHESTRATOR_BASE_URL=
# AGENTIS_ORCHESTRATOR_API_KEY=
# AGENTIS_ORCHESTRATOR_MODEL=
