    "@agentis/db": "workspace:*",
    "@agentis/sdk": "workspace:*",
    "@agentis/web": "workspace:*",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.5.4"
  }
