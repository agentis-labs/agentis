{
  "name": "@agentis-labs/cli",
  "version": "0.3.0",
  "description": "Multi-harness dashboard for agents you own — Claude Code, Codex, Cursor, Antigravity, Hermes, and OpenClaw, with a permanent Brain of memory that survives any harness or model swap. Install with `npm install -g @agentis-labs/cli`.",
  "license": "Apache-2.0",
  "author": "Robson Prado <robsonpradodev>",
  "homepage": "https://useagentis.com",
