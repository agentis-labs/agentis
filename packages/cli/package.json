{
  "name": "@agentis-labs/cli",
  "version": "0.2.0",
  "description": "Open-source, self-hosted command center for agents you own. Run `npx @agentis-labs/cli@latest up`.",
  "license": "Apache-2.0",
  "author": "Robson Prado <robsonpradodev>",
  "homepage": "https://github.com/agentis-labs/agentis#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentis-labs/agentis.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/agentis-labs/agentis/issues"
  },
  "keywords": [
    "agentis",
    "agent",
    "dashboard",
    "workflow",
    "automation",
    "ambient",
    "ai"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "bin": {
    "agentis": "dist/index.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'ok'",
    "test": "echo 'no tests yet'",
    "prepack": "node scripts/prepack.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "playwright": "^1.60.0"
  },
  "devDependencies": {
    "@agentis/api": "workspace:*",
    "@agentis/core": "workspace:*",
    "@agentis/db": "workspace:*",
    "@agentis/sdk": "workspace:*",
    "@agentis/web": "workspace:*",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
