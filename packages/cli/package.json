    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/agentis-labs/agentis/issues"
  },
  "keywords": [
    "agentis",
    "agent",
    "agents",
    "dashboard",
    "control-panel",
    "harness",
    "multi-harness",
    "claude-code",
    "codex",
    "cursor",
    "openclaw",
    "hermes",
    "antigravity",
    "gemini-cli",
    "cli",
    "workflow",
    "workflow-engine",
    "orchestration",
    "memory",
    "brain",
    "self-hosted",
    "automation",
    "ambient",
    "ai"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "bin": {
    "agentis": "dist/index.cjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "publishConfig": {
