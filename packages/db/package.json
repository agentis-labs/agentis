{
  "name": "@agentis/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./sqlite": "./src/sqlite/index.ts",
    "./pg": "./src/pg/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'ok'",
    "test": "echo 'no tests yet'",
    "generate:sqlite": "drizzle-kit generate --config=drizzle.sqlite.config.ts",
    "generate:pg": "drizzle-kit generate --config=drizzle.pg.config.ts"
  },
  "dependencies": {
    "@agentis/core": "workspace:*",
    "better-sqlite3": "^12.4.1",
    "drizzle-orm": "^0.34.0",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "drizzle-kit": "^0.25.0",
    "typescript": "^5.5.4"
  }
}
