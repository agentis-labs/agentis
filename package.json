{
  "name": "agentis",
  "version": "0.1.0",
  "private": true,
  "description": "Agentis — the operating system for agentic software.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build && pnpm --filter @agentis/web build && pnpm --filter @agentis/api build",
    "dev": "pnpm --filter @agentis/api dev",
    "dev:web": "pnpm --filter @agentis/web dev",
    "dev:full": "concurrently --raw --kill-others-on-fail -n api,web -c blue,magenta \"pnpm --filter @agentis/api dev\" \"pnpm --filter @agentis/web dev\"",
    "agentis": "pnpm --filter @agentis-ai/cli start",
    "agentis:up": "pnpm --filter @agentis-ai/cli start up",
    "doctor": "tsx scripts/agentis-doctor.ts",
    "workflow:audit": "tsx scripts/workflow-reliability-audit.ts --write",
    "lint": "node scripts/check-boundaries.mjs && node scripts/check-security-invariants.mjs && node scripts/check-file-budget.mjs && pnpm -r lint",
    "lint:boundaries": "node scripts/check-boundaries.mjs",
    "lint:security": "node scripts/check-security-invariants.mjs",
    "lint:budget": "node scripts/check-file-budget.mjs --warn",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,html}\"",
    "db:generate": "pnpm --filter @agentis/db generate",
    "db:migrate": "pnpm --filter @agentis/db migrate"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.14.10",
    "concurrently": "^9.0.1",
    "knip": "^6.25.0",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^5.5.4"
  }
}
