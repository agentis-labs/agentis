{
  "name": "agentis",
  "version": "0.1.0",
  "private": true,
  "description": "Agentis — the operating system for agentic software.",
  "license": "Apache-2.0",
  "homepage": "https://useagentis.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentis-labs/agentis.git"
  },
  "bugs": {
    "url": "https://github.com/agentis-labs/agentis/issues"
  },
  "keywords": [
    "agentis",
    "agents",
    "agentic-ai",
    "workflow-engine",
    "automation",
    "self-hosted",
    "typescript"
  ],
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build && pnpm --filter @agentis/web build && pnpm --filter @agentis/api build",
    "dev": "pnpm --filter @agentis/api dev",
    "dev:web": "pnpm --filter @agentis/web dev",
    "dev:full": "concurrently --raw --kill-others-on-fail -n api,web -c blue,magenta \"pnpm --filter @agentis/api dev\" \"pnpm --filter @agentis/web dev\"",
    "agentis": "pnpm --filter @agentis-labs/cli start",
    "agentis:up": "pnpm --filter @agentis-labs/cli start up",
    "doctor": "tsx scripts/agentis-doctor.ts",
    "workflow:audit": "tsx scripts/workflow-reliability-audit.ts --write",
    "lint": "node scripts/check-boundaries.mjs && node scripts/check-security-invariants.mjs && node scripts/check-file-budget.mjs && pnpm -r lint",
    "lint:boundaries": "node scripts/check-boundaries.mjs",
    "lint:security": "node scripts/check-security-invariants.mjs",
    "lint:budget": "node scripts/check-file-budget.mjs --warn",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,html}\"",
    "db:generate": "pnpm --filter @agentis/db generate",
    "db:migrate": "pnpm --filter @agentis/db migrate"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.14.10",
    "concurrently": "^9.0.1",
    "knip": "^6.25.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^7.0.2"
  },
  "pnpm": {
    "overrides": {
      "adm-zip": "0.6.0",
      "shell-quote": "1.9.0",
      "tmp": "0.2.7",
      "ws": "8.21.0",
      "vite": "6.4.3",
      "jsdom>undici": "7.28.0",
      "discord.js>undici": "6.27.0",
      "@discordjs/rest>undici": "6.27.0",
      "minimatch@5>brace-expansion": "2.1.2",
      "minimatch@3>brace-expansion": "1.1.16",
      "onnxruntime-web": "link:./packages/stubs/onnxruntime-web"
    }
  }
}
